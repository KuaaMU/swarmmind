{
  "name": "swarmmind",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.9.0",
  "description": "Autonomous multi-agent DeFi intelligence network on X Layer",
  "workspaces": [
    "packages/contracts",
    "packages/shared-types",
    "packages/agents/shared",
    "packages/agents/alpha-scout",
    "packages/agents/risk-oracle",
    "packages/agents/trade-executor",
    "packages/agents/portfolio-manager",
    "packages/agents/liquidity-agent",
    "packages/consensus",
    "packages/dashboard"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "eslint \"packages/**/*.ts\"",
    "lint:fix": "eslint \"packages/**/*.ts\" --fix",
    "format": "prettier --write \"packages/**/*.ts\"",
    "format:check": "prettier --check \"packages/**/*.ts\"",
    "test": "turbo run test",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  }
}
